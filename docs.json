{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Logo Soup",
  "theme": "palm",
  "colors": {
    "primary": "#f36458",
    "light": "#ff8a7a",
    "dark": "#d44a3e"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/sanity-labs/logo-soup"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/sanity-labs/logo-soup"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Framework Guides",
            "pages": [
              "frameworks/react",
              "frameworks/vue",
              "frameworks/svelte",
              "frameworks/solid",
              "frameworks/angular",
              "frameworks/jquery",
              "frameworks/vanilla",
              "frameworks/custom"
            ]
          },
          {
            "group": "Guides",
            "pages": ["options", "how-it-works"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api-reference/create-logo-soup",
              "api-reference/get-visual-center-transform",
              "api-reference/utilities",
              "api-reference/types"
            ]
          }
        ]
      }
    ]
  }
}
